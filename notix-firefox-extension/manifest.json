{
  "manifest_version": 3,
  "name": "Notix",
  "version": "1.0.0",
  "description": "A beautiful minimal note-taking extension for Firefox with rich text support, sidebar, and quick capture.",
  "author": "Arvanta",
  "browser_specific_settings": {
    "gecko": {
      "id": "notix_arvanta@github.com",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icons/light/icon16.png",
    "32": "icons/light/icon32.png",
    "48": "icons/light/icon48.png",
    "128": "icons/light/icon128.png"
  },
  "permissions": [
    "storage",
    "contextMenus",
    "activeTab"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "sidebar_action": {
    "default_panel": "sidebar.html",
    "default_title": "Notix",
    "default_icon": "icons/light/icon32.png"
  },
  "commands": {
    "_execute_sidebar_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Open Notix sidebar"
    }
  },
  "action": {
    "default_title": "Open Notix Sidebar",
    "default_icon": {
      "16": "icons/light/icon16.png",
      "32": "icons/light/icon32.png",
      "48": "icons/light/icon48.png"
    }
  }
}